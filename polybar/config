[colors]
top-background = #70000000
top-foreground = #f3f4f5

bottom-background = #00ffffff
bottom-foreground = #70ffffff

primary = #ffb52a
secondary = #e60053
shaded = #002f343f
alert = #bd2c40
highlight = #D9583C

[global/wm]
margin-top = 5
margin-bottom = 5

[bar/topbar]
monitor = ${env:MONITOR:eDP-1}
width = 100%
height = 25
offset-x = 0
offset-y = 0
radius = 0.0
fixed-center = true
bottom = true

background = ${colors.top-background}
foreground = ${colors.top-foreground}

line-size = 0

border-size = 0
border-color = #00000000

padding-right = 1

module-margin = 1

font-0 = Monaco for Powerline:size=8;2
font-1 = Material Design Icons:size=8;2
font-2 = Material\-Design\-Iconic\-Font:size=8;2
font-3 = FontAwesome:size=8;2
font-4 = Noto Sans:size=8;2

modules-left = i3
modules-center = 
modules-right = filesystem temperature cpu memory xbacklight volume wlan eth battery date

tray-position = right
; tray-padding = 2
tray-transparent = true
tray-detached = false

; wm-restack = i3

; override-redirect = true

;scroll-up = i3wm-wsnext
;scroll-down = i3wm-wsprev

[bar/bottombar]
monitor = ${env:MONITOR:eDP-1}
width = 100%
height = 35
offset-x = 0
offset-y = 0
radius = 0.0
fixed-center = true
bottom = true

background = ${colors.bottom-background}
foreground = ${colors.bottom-foreground}

line-size = 0

border-size = 0
border-color = #00000000

padding-left = 5
padding-right = 5

module-margin-left = 2
module-margin-right = 2

font-0 = Monaco for Powerline:size=8;2
font-1 = Material Design Icons:size=8;2
font-2 = Material\-Design\-Iconic\-Font:size=8;2
font-3 = FontAwesome:size=8;2

modules-left = 
modules-right =  temperature cpu memory
modules-center = i3

override-redirect = true
wm-restack = i3


[module/xwindow]
type = internal/xwindow
label = %title:0:30:...%

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = "´ŐĄ "
format-prefix-foreground = ${bar/bottombar.foreground}
format-prefix-underline = ${colors.secondary}

label-layout = %layout%
label-layout-underline = ${colors.secondary}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${colors.secondary}
label-indicator-underline = ${colors.secondary}

[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /
mount-1 = /home

label-mounted = %{F#ffffff}%mountpoint%%{F-}: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${bar/topbar.foreground}

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = false
enable-scroll = false
wrapping-scroll = false

; Only show workspaces on the same output as the bar
pin-workspaces = true

label-focused-foreground = #f3f4f5
label-unfocused-foreground = #676E7D
label-urgent-background = #E53935
label-urgent-foreground = #f3f4f5
label-urgent-padding-right = 1
; label-mode-foreground = ${bar/bottombar.foreground}
; label-mode-background = ${bar/bottombar.background}

; ; focused = Active workspace on focused monitor2
; label-focused-background = ${colors.shaded}
; label-focused-underline = ${module/bspwm.label-focused-underline}
; label-focused-padding = ${module/bspwm.label-focused-padding}

; ; unfocused = Inactive workspace on any monitor
; label-unfocused-padding = ${module/bspwm.label-occupied-padding}

; ; visible = Active workspace on unfocused monitor
; label-visible = %index%
; label-visible-background = ${self.label-focused-background}
; label-visible-underline = ${self.label-focused-underline}
; label-visible-padding = ${self.label-focused-padding}

; ; urgent = Workspace with urgency hint set
; label-urgent = "´ëČ"
; label-urgent-font = 3
; label-urgent-foreground = ${module/bspwm.label-urgent-foreground}
; label-urgent-padding = ${module/bspwm.label-urgent-padding}

[module/mpd]
type = internal/mpd
format-online = <label-song>  <icon-prev> <icon-stop> <toggle> <icon-next>

icon-prev = ţéľ
icon-stop = ţéÖ
icon-play = ţéÜ
icon-pause = ţéŤ
icon-next = ţéť

label-song-maxlen = 25
label-song-ellipsis = true

[module/xbacklight]
type = internal/xbacklight
card = intel_backlight

format = <ramp> <bar>

ramp-0 = ´â×
ramp-1 = ´âŁ
ramp-2 = ´âá
ramp-font = 2

bar-width = 10
bar-indicator = ´äĹ
bar-indicator-foreground = #f3f4f5
bar-indicator-font = 4
bar-fill = ´üĘ
bar-fill-font = 4
bar-fill-foreground = #f3f4f5
bar-empty = ´üĘ
bar-empty-font = 4
bar-empty-foreground = #676E7D

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "´ŹŤ "
format-prefix-foreground = ${bar/topbar.foreground}
;format-underline = #f90000
label = %percentage%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "´śÜ "
format-prefix-foreground = ${bar/topbar.foreground}
;format-underline = #4bffdc
label = %percentage_used%%

[module/wlan]
type = internal/network
interface = wlp2s0
interval = 3.0

format-connected = <ramp-signal> <label-connected>
format-prefix = 1
format-connected-underline = #9f78e1
label-connected = %essid%
label-connected-foreground = ${bar/topbar.foreground}

;format-disconnected-prefix = "´őŽ "
;format-disconnected-prefix-font = 3
;format-disconnected = no network
format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${bar/topbar.foreground}

label-disconnected = ´őŽ
label-disconnected-font = 3
label-disconnected-foreground = ${bar/topbar.foreground}

ramp-signal-0 = ´őž
ramp-signal-1 = ´őó
ramp-signal-2 = ´őĘ
ramp-signal-font = 3
ramp-signal-foreground = ${bar/topbar.foreground}

[module/eth]
type = internal/network
interface = enp1s0
interval = 3.0

format-connected-underline = #55aa55
format-connected-prefix = "´äł "
format-connected-prefix-foreground = ${bar/topbar.foreground}
label-connected = %local_ip%

; format-disconnected =
; format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${bar/topbar.foreground}

[module/date]
type = internal/date
interval = 1

date = "´âÂ %a %e %b"

time = "| %H:%M"

format-prefix-foreground = ${bar/topbar.foreground}
format-underline = ${bar/topbar.foreground}

format = <label>
label = %date% %time%
label-font = 2

[module/volume]
type = internal/volume

format-volume = <ramp-volume> <bar-volume>
label-volume = VOL
label-volume-foreground = ${root.foreground}

ramp-volume-0 = ´Ľ┐
ramp-volume-1 = ´ľÇ
ramp-volume-2 = ´Ľż
ramp-volume-foreground = ${bar/topbar.foreground}

format-muted = "´ľü"
format-muted-foreground = #f3f4f5

bar-volume-width = 10
bar-volume-indicator = ´äĹ
bar-volume-indicator-font = 4
bar-volume-indicator-foreground = #f3f4f5
bar-volume-fill = ´üĘ
bar-volume-fill-font = 4
bar-volume-empty = ´üĘ
bar-volume-empty-font = 4
bar-volume-empty-foreground = #676E7D

[module/battery]
type = internal/battery
battery = BAT1
adapter = AC
full-at = 98

time-format = %H:%M

format-charging = <animation-charging> <label-charging>
format-charging-underline = #ffb52a

format-discharging = <ramp-capacity> <label-discharging>
format-discharging-underline = ${self.format-charging-underline}

format-full = <label-full> 100%
format-full-prefix-foreground = ${bar/topbar.foreground}
format-full-underline = ${self.format-charging-underline}

label-discharging-foreground = ${bar/topbar.foreground}
label-charging-foreground = ${bar/topbar.foreground}
label-full = "´ü╣"
label-full-font = 2

ramp-capacity-0 = "´éâ"
ramp-capacity-1 = "´éÄ"
ramp-capacity-2 = "´ü║"
ramp-capacity-3 = "´ü╗"
ramp-capacity-4 = "´ü╝"
ramp-capacity-5 = "´üŻ"
ramp-capacity-6 = "´üż"
ramp-capacity-7 = "´ü┐"
ramp-capacity-8 = "´éÇ"
ramp-capacity-9 = "´éü"
ramp-capacity-10 = "´éé"
ramp-capacity-11 = "´ü╣"
ramp-capacity-font = 2
ramp-capacity-foreground = ${bar/topbar.foreground}

animation-charging-0 = "´éć"
animation-charging-1 = "´éç"
animation-charging-2 = "´éł"
animation-charging-3 = "´éë"
animation-charging-4 = "´éŐ"
animation-charging-5 = "´éů"
animation-charging-foreground = ${bar/topbar.foreground}
animation-charging-framerate = 650
animation-charging-font = 2

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 70

format = <ramp> <label>
format-warn = <ramp> <label-warn>

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = #E53935

ramp-0 = ´öĆ
ramp-font = 3
ramp-foreground = ${bar/topbar.foreground}

[module/powermenu]
type = custom/menu

format-spacing = 1

label-open = ´ÉŽ
label-open-padding = 1
label-open-foreground = ${bar/topbar.foreground}

label-close = ´ůÜ
label-close-padding = 1
label-close-foreground = ${bar/topbar.foreground}

label-separator = |
label-separator-foreground = ${bar/topbar.foreground}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = reboot

menu-2-0 = power off
menu-2-0-exec = poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

[module/weather]
type = custom/script
interval = 10
format = <label>
exec = ~/.config/polybar/weather

[module/redshift]
type = custom/script
interval = 5

exec = ~/.config/polybar/redshift.sh

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over

; vim:ft=dosini

[module/github]
type = internal/github

format = <label>
format-prefix = "´éŤ "
format-prefix-foreground = ${bar/bottombar.foreground}

label = %notifications%

token = ${file:/home/metamist/secret/github.token}

empty-notifications = true

[module/music]
type = custom/script
interval = 2

label = %output:0:45:...%
label-foreground = ${colors.highlight}
exec = ~/.config/polybar/mpris.sh
click-left = playerctl previous
click-middle = playerctl play-pause
click-right = playerctl next


